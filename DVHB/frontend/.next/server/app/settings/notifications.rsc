<button class="px-8 py-3 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-xl">save</span>
                            Save Preferences
                        </button>
</div>
</div>
</main>
</div>
