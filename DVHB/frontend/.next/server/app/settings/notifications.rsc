9:T2e14,<div class="flex flex-col min-h-screen">
<!-- Top Navigation -->
<header class="h-16 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark px-6 flex items-center justify-between sticky top-0 z-10">
<div class="flex items-center gap-8">
<div class="flex items-center gap-2 text-primary">
<img alt="DEVHUB logo" class="size-8 rounded-lg object-cover" src="/assets/devhublogo.jpeg"/>
<h2 class="text-xl font-black tracking-tight">DEVHUB</h2>
</div>
<div class="hidden md:flex relative group">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
<input class="pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary w-64 text-sm transition-all" placeholder="Search settings..." type="text"/>
</div>
</div>
<div class="flex items-center gap-4">
<button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full relative">
<span class="material-symbols-outlined">notifications</span>
<span class="absolute top-2 right-2 w-2 h-2 bg-primary rounded-full"></span>
</button>
<button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full">
<span class="material-symbols-outlined">settings</span>
</button>
<div class="h-8 w-8 rounded-full bg-primary/20 flex items-center justify-center overflow-hidden border border-primary/30">
<img class="w-full h-full object-cover" data-alt="User avatar profile picture" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB3iqY6gx512mQ8m_dHHVANKI1RH8W2VjR1Rq4Tw4KUzzFn-uZjZSBibD_cZIbEMY8S2TvroU9LGas9H_o4pCO0usYk5scWvJnDHV7__KBgQVw_kk8Li24DkIymq8mGM8cE1iJhqSmnf879ZaIyaLZSqHiH4hepMlpMMa0VrFqeexqi8zr4X21ljmcbdf3Cg2mMSJysNut_v6BKrJS6OqO3WmpNNb6ja84oacsFbVbTXoKuB1MwdjYwY9kLeowBbgAIYac6Gz1F3xuu"/>
</div>
</div>
</header>
<div class="flex flex-1">
<!-- Sidebar -->
<aside class="w-64 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark hidden lg:block">
<nav class="p-4 space-y-1">
<a class="flex items-center gap-3 px-3 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors" href="/dashboard">
<span class="material-symbols-outlined">grid_view</span>
<span class="font-medium">Dashboard</span>
</a>
<a class="flex items-center gap-3 px-3 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors" href="/projects/new">
<span class="material-symbols-outlined">terminal</span>
<span class="font-medium">Projects</span>
</a>
<a class="flex items-center gap-3 px-3 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors" href="/settings/team">
<span class="material-symbols-outlined">group</span>
<span class="font-medium">Team</span>
</a>
<a class="flex items-center gap-3 px-3 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors" href="/solutions">
<span class="material-symbols-outlined">monitoring</span>
<span class="font-medium">Analytics</span>
</a>
<div class="pt-4 pb-2 px-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Settings</div>
<a class="flex items-center gap-3 px-3 py-3 rounded-lg bg-primary/10 text-primary border-l-4 border-primary transition-colors" href="/settings/notifications">
<span class="material-symbols-outlined">notifications_active</span>
<span class="font-medium">Notification Prefs</span>
</a>
<a class="flex items-center gap-3 px-3 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors" href="/settings/security">
<span class="material-symbols-outlined">security</span>
<span class="font-medium">Security</span>
</a>
</nav>
</aside>
<!-- Main Content -->
<main class="flex-1 p-4 md:p-8 max-w-5xl mx-auto w-full">
<div class="mb-8">
<h1 class="text-3xl font-black text-slate-900 dark:text-slate-100 tracking-tight">Notification Preferences</h1>
<p class="text-slate-500 dark:text-slate-400 mt-2">Choose how and when you want to stay updated with DEVHUB activity.</p>
</div>
<div class="space-y-6">
<!-- Account Alerts Group -->
<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
<h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">Account Alerts</h2>
<p class="text-sm text-slate-500">Important updates about your account status and subscriptions.</p>
</div>
<div class="divide-y divide-slate-100 dark:divide-slate-800">
<!-- Order Updates -->
<div class="px-6 py-5 flex flex-col md:flex-row md:items-center justify-between gap-4">
<div>
<h3 class="font-semibold">Order Updates</h3>
<p class="text-sm text-slate-500">Notifications about your billing and active subscriptions.</p>
</div>
<div class="flex gap-4 md:gap-8">
