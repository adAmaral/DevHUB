<span class="text-sm font-medium">SMS</span>
</div>
</div>
</div>
</div>
</section>
<!-- Marketing Group -->
<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
<h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">Marketing &amp; Promotions</h2>
<p class="text-sm text-slate-500">Stay in the loop with the latest news and offers.</p>
</div>
<div class="divide-y divide-slate-100 dark:divide-slate-800">
<!-- Newsletters -->
<div class="px-6 py-5 flex flex-col md:flex-row md:items-center justify-between gap-4">
<div>
<h3 class="font-semibold">Newsletters</h3>
<p class="text-sm text-slate-500">Weekly digest of top developer news and trends.</p>
</div>
<div class="flex gap-4 md:gap-8">
<div class="flex items-center gap-2">
<input checked="" class="w-5 h-5 rounded border-slate-300 text-primary focus:ring-primary" type="checkbox"/>
<span class="text-sm font-medium">Email</span>
</div>
<div class="flex items-center gap-2 opacity-50 cursor-not-allowed">
<input class="w-5 h-5 rounded border-slate-300 bg-slate-100" disabled="" type="checkbox"/>
<span class="text-sm font-medium">Push</span>
</div>
</div>
</div>
<!-- Promotions -->
<div class="px-6 py-5 flex flex-col md:flex-row md:items-center justify-between gap-4">
<div>
<h3 class="font-semibold">Promotions</h3>
<p class="text-sm text-slate-500">Exclusive discounts and partner offers for developers.</p>
</div>
<div class="flex gap-4 md:gap-8">
<div class="flex items-center gap-2">
<input class="w-5 h-5 rounded border-slate-300 text-primary focus:ring-primary" type="checkbox"/>
<span class="text-sm font-medium">Email</span>
</div>
<div class="flex items-center gap-2">
<input class="w-5 h-5 rounded border-slate-300 text-primary focus:ring-primary" type="checkbox"/>
<span class="text-sm font-medium">Push</span>
</div>
</div>
</div>
</div>
</section>
<!-- Security Group -->
<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
<div class="flex items-center gap-2">
<h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">Security</h2>
<span class="bg-primary/10 text-primary text-[10px] font-bold px-1.5 py-0.5 rounded uppercase tracking-tighter">Recommended</span>
</div>
<p class="text-sm text-slate-500">Critical notifications to keep your workspace safe.</p>
</div>
<div class="divide-y divide-slate-100 dark:divide-slate-800">
<!-- Login Alerts -->
<div class="px-6 py-5 flex flex-col md:flex-row md:items-center justify-between gap-4">
<div>
<h3 class="font-semibold">Login Alerts</h3>
<p class="text-sm text-slate-500">Notify me when a new device logs into my account.</p>
</div>
<div class="flex gap-4 md:gap-8">
<div class="flex items-center gap-2">
<input checked="" class="w-5 h-5 rounded border-slate-300 text-primary focus:ring-primary" type="checkbox"/>
<span class="text-sm font-medium">Email</span>
</div>
<div class="flex items-center gap-2">
<input checked="" class="w-5 h-5 rounded border-slate-300 text-primary focus:ring-primary" type="checkbox"/>
<span class="text-sm font-medium">Push</span>
</div>
