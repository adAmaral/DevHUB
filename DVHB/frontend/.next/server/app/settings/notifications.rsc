</div>
</div>
</div>
</section>
<!-- Action Footer -->
<div class="flex items-center justify-between pt-4">
<button class="px-6 py-2.5 rounded-xl text-slate-600 dark:text-slate-400 font-bold hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors">
