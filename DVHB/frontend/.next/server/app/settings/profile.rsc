9:T2bc2,<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
<!-- Top Navigation Bar -->
<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 py-3 md:px-10">
<div class="flex items-center gap-8">
<div class="flex items-center gap-3 text-primary">
<div class="size-8 flex items-center justify-center">
<img alt="DEVHUB logo" class="size-8 rounded-lg object-cover" src="/assets/devhublogo.jpeg"/>
</div>
<h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold leading-tight tracking-tight" style="">DEVHUB</h2>
</div>
<label class="hidden md:flex flex-col min-w-40 h-10 max-w-64" style="">
<div class="flex w-full flex-1 items-stretch rounded-lg h-full">
<div class="text-slate-500 flex border-none bg-slate-100 dark:bg-slate-800 items-center justify-center pl-4 rounded-l-lg">
<span class="material-symbols-outlined text-lg" style="">search</span>
</div>
<input class="form-input flex w-full min-w-0 flex-1 border-none bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-0 h-full placeholder:text-slate-500 px-4 rounded-r-lg text-sm" placeholder="Search settings..." value="">
</div>
</label>
</div>
<div class="flex flex-1 justify-end gap-4 items-center">
<div class="flex gap-2">
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300" style="">
<span class="material-symbols-outlined" style="">notifications</span>
</button>
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300" style="">
<span class="material-symbols-outlined" style="">settings</span>
</button>
</div>
<div class="h-10 w-10 rounded-full bg-primary/20 bg-cover bg-center border-2 border-primary/10" data-alt="User profile avatar of a developer" style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuDGvaP7kpxfcXMYsaPPemylEJoSonb2Gft0Q-jGTEobWITpOGNtnqB-WxuTwPFyLlSziBZ8tu6R5eWACYRXkWhkOGLq-7RVoLgsp2w8ozeKfVXJB2XC25fj9ZuejH-EEzENdjGWeNC1mNdwVdL9F_tsD-Qt5p_OJiTY4EOtUhik2MbZ4Xxd3x8Ifhkl_6SX0u1DdUoUBOoDDQAyqZ2eB0XzOaI6ps5HeXc9dILCJKJiZFwl4jkP3XWSQwK11re44lVUMTS2CQApTN9R&quot;);"></div>
</div>
</header>
<main class="flex-1 flex flex-col md:flex-row max-w-[1200px] mx-auto w-full p-4 md:p-8 gap-8">
<!-- Sidebar Navigation -->
<aside class="w-full md:w-64 flex flex-col gap-2 shrink-0">
<div class="mb-4">
<h1 class="text-slate-900 dark:text-slate-100 text-2xl font-black tracking-tight" style="">Settings</h1>
<p class="text-slate-500 text-sm" style="">Manage your workspace</p>
</div>
<nav class="flex flex-col gap-1">
<a class="flex items-center gap-3 px-4 py-3 rounded-xl bg-primary text-white font-semibold shadow-sm shadow-primary/20" href="/settings/profile" style="">
<span class="material-symbols-outlined text-[22px]" style="">person</span>
<span class="text-sm" style="">Personal Info</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 font-medium transition-colors" href="/settings/security" style="">
<span class="material-symbols-outlined text-[22px]" style="">lock</span>
<span class="text-sm" style="">Security &amp; Password</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 font-medium transition-colors" href="/settings/billing" style="">
<span class="material-symbols-outlined text-[22px]" style="">business_center</span>
<span class="text-sm" style="">Billing &amp; Payments</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 font-medium transition-colors" href="/settings/notifications" style="">
<span class="material-symbols-outlined text-[22px]" style="">notifications</span>
<span class="text-sm" style="">Notification Preferences</span>
</a>
</nav>
<div class="mt-8 p-4 bg-primary/5 rounded-xl border border-primary/10">
<p class="text-xs font-bold text-primary uppercase tracking-wider mb-2" style="">Current Plan</p>
<div class="flex items-center justify-between">
<span class="text-sm font-bold text-slate-900 dark:text-slate-100" style="">Enterprise Elite</span>
<span class="px-2 py-0.5 rounded bg-primary/20 text-primary text-[10px] font-black" style="">ACTIVE</span>
</div>
</div>
</aside>
<!-- Main Content Area -->
<section class="flex-1">
<div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
<!-- Header -->
<div class="p-6 md:p-8 border-b border-slate-100 dark:border-slate-800 flex flex-wrap items-center justify-between gap-4">
<div>
<h2 class="text-xl font-bold text-slate-900 dark:text-slate-100" style="">Personal Information</h2>
<p class="text-slate-500 text-sm mt-1" style="">Update your photo and personal details here.</p>
</div>
<div class="flex items-center gap-2 px-3 py-1.5 bg-primary/10 rounded-full border border-primary/20">
<span class="size-2 rounded-full bg-primary"></span>
<span class="text-xs font-bold text-primary" style="">Company Account</span>
</div>
</div>
<!-- Form Content -->
<div class="p-6 md:p-8">
<div class="space-y-8">
<!-- Avatar Section -->
<div class="flex flex-col md:flex-row items-center gap-6">
<div class="relative group">
<div class="size-28 rounded-full bg-slate-200 dark:bg-slate-800 border-4 border-white dark:border-slate-700 shadow-md bg-cover bg-center overflow-hidden" data-alt="Close up of a professional male developer" style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuBPlG5t4_rOUEaHGm1xWZkzwLjCgp6BqfCIWGem91uWilGGBZDbis_NmLwPYWkhqUXfucFDz-x2lA1vB-g-meZ7if9KNdaIQhp4ta4DqcHQcqG0pkdChWkqF5Rw1eSM0FIP8WgduvHkj0PJCixUoLx42Z8ZBSdn9julRzCFnl7owl9ml-JQjuS8RiF2xzISH9_QXlfyWIRyvhXTTA5xkLiNEWbYgbFdn5vnNKlsV2oC4sXiDstbDcSYLASrenq1XBkuKwL1G2GYxVjU&quot;);">
<div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
<span class="material-symbols-outlined text-white" style="">photo_camera</span>
</div>
</div>
<button class="absolute bottom-0 right-0 bg-primary text-white p-1.5 rounded-full shadow-lg border-2 border-white dark:border-slate-900" style="">
<span class="material-symbols-outlined text-sm" style="">edit</span>
</button>
</div>
<div class="flex flex-col gap-2 text-center md:text-left">
<h3 class="text-lg font-bold text-slate-900 dark:text-slate-100" style="">Profile Picture</h3>
<p class="text-slate-500 text-sm" style="">JPG, GIF or PNG. Recommended size 400x400px. Max size 800K.</p>
<div class="flex gap-3 justify-center md:justify-start mt-1">
<button class="px-4 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors" style="">Upload New</button>
<button class="px-4 py-2 text-sm font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors" style="">Remove</button>
</div>
</div>
</div>
<!-- Input Fields -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="flex flex-col gap-2">
<label class="text-sm font-bold text-slate-700 dark:text-slate-300" style="">Full Name</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-primary h-11" type="text" value="Alex Richardson">
</div>
<div class="flex flex-col gap-2">
<label class="text-sm font-bold text-slate-700 dark:text-slate-300" style="">Email Address</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-primary h-11" type="email" value="alex.richardson@devhub.com">
</div>
<div class="flex flex-col gap-2">
<label class="text-sm font-bold text-slate-700 dark:text-slate-300" style="">Phone Number</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-primary h-11" type="tel" value="+1 (555) 123-4567">
</div>
<div class="flex flex-col gap-2">
<label class="text-sm font-bold text-slate-700 dark:text-slate-300" style="">Job Title</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-primary h-11" type="text" value="Senior Full Stack Engineer">
</div>
</div>
<div class="flex flex-col gap-2">
<label class="text-sm font-bold text-slate-700 dark:text-slate-300" style="">Professional Bio</label>
<textarea class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-primary" rows="4">Focused on building scalable infrastructure and modern web applications. Avid open-source contributor and mentor.</textarea>
</div>
</div>
</div>
<!-- Actions Footer -->
<div class="p-6 md:p-8 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-100 dark:border-slate-800 flex items-center justify-end gap-4">
<a class="text-sm font-medium text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 transition-colors" href="/dashboard" style="">Cancel</a>
<button onclick="showProfileToast()" class="px-8 py-2.5 bg-primary text-white font-bold rounded-lg shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all active:scale-95" style="">
                            Save Changes
                        </button>
</div>
</div>
<!-- Danger Zone Section -->
<div class="mt-8 bg-red-50/50 dark:bg-red-900/10 rounded-xl border border-red-100 dark:border-red-900/30 p-6 flex flex-wrap items-center justify-between gap-4">
<div>
<h4 class="text-red-700 dark:text-red-400 font-bold" style="">Deactivate Account</h4>
<p class="text-red-600/70 dark:text-red-400/60 text-sm" style="">Once you deactivate your account, there is no going back. Please be certain.</p>
</div>
<button class="px-4 py-2 bg-white dark:bg-slate-900 text-red-600 border border-red-200 dark:border-red-900 font-bold rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" style="">
                        Deactivate
                    </button>
</div>
</section>
</main>
<div id="profile-save-toast" class="fixed bottom-6 right-6 hidden rounded-lg bg-emerald-600 text-white px-4 py-3 text-sm font-semibold shadow-lg z-50">Profile updated successfully.</div>
<script>function showProfileToast(){const el=document.getElementById('profile-save-toast');if(!el)return;el.classList.remove('hidden');setTimeout(()=>el.classList.add('hidden'),2200);}</script>
<footer class="p-10 text-center text-slate-400 dark:text-slate-600 text-sm">
<p class="" style="">© 2026 DEVHUB Ecosystem. All rights reserved.</p>
</footer>
