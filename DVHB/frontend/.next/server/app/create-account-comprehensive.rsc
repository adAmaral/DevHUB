9:T239e,<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-primary/10 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md px-6 md:px-10 py-4 sticky top-0 z-50">
<div class="flex items-center gap-4 text-slate-900 dark:text-slate-100">
<div class="size-8 flex items-center justify-center">
<img alt="DEVHUB logo" class="size-8 rounded-lg object-cover" src="/assets/devhublogo.jpeg"/>
</div>
<h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold leading-tight tracking-[-0.015em]">DEVHUB</h2>
</div>
<div class="flex items-center gap-4">
<span class="text-sm text-slate-600 dark:text-slate-400 hidden sm:inline">Already have an account?</span>
<button class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 transition-colors">
<span class="truncate">Log In</span>
</button>
</div>
</header>
<main class="flex-1 flex items-center justify-center p-4 md:p-8">
<div class="w-full max-w-[560px] bg-white dark:bg-slate-900 rounded-xl shadow-xl border border-primary/5 p-6 md:p-10">
<div class="mb-8">
<h1 class="text-slate-900 dark:text-slate-100 text-3xl font-black leading-tight tracking-[-0.033em]">Create Account</h1>
<p class="text-slate-500 dark:text-slate-400 text-base mt-2">Join the largest developer ecosystem today</p>
</div>
<div class="mb-8">
<p class="text-slate-900 dark:text-slate-100 text-sm font-bold leading-tight tracking-[-0.015em] mb-4">Select User Type</p>
<div class="grid grid-cols-3 gap-3 p-1 bg-background-light dark:bg-slate-800 rounded-xl">
<label class="group relative flex cursor-pointer flex-col items-center justify-center rounded-lg py-3 px-2 text-center transition-all has-[:checked]:bg-white dark:has-[:checked]:bg-slate-700 has-[:checked]:shadow-sm has-[:checked]:text-primary text-slate-500 dark:text-slate-400">
<input class="sr-only" name="user_type" type="radio" value="company"/>
<span class="material-symbols-outlined text-2xl mb-1">domain</span>
<span class="text-xs font-semibold uppercase tracking-wider">Company</span>
</label>
<label class="group relative flex cursor-pointer flex-col items-center justify-center rounded-lg py-3 px-2 text-center transition-all has-[:checked]:bg-white dark:has-[:checked]:bg-slate-700 has-[:checked]:shadow-sm has-[:checked]:text-primary text-slate-500 dark:text-slate-400">
<input checked="" class="sr-only" name="user_type" type="radio" value="regular"/>
<span class="material-symbols-outlined text-2xl mb-1">person</span>
<span class="text-xs font-semibold uppercase tracking-wider">Regular</span>
</label>
<label class="group relative flex cursor-pointer flex-col items-center justify-center rounded-lg py-3 px-2 text-center transition-all has-[:checked]:bg-white dark:has-[:checked]:bg-slate-700 has-[:checked]:shadow-sm has-[:checked]:text-primary text-slate-500 dark:text-slate-400">
<input class="sr-only" name="user_type" type="radio" value="supplier"/>
<span class="material-symbols-outlined text-2xl mb-1">inventory_2</span>
<span class="text-xs font-semibold uppercase tracking-wider">Supplier</span>
</label>
</div>
</div>
<form class="space-y-5">
<!-- Dynamic Content: Regular User View (Default) -->
<div class="space-y-5" id="regular-fields">
<div class="flex flex-col gap-2">
<label class="text-slate-900 dark:text-slate-100 text-sm font-semibold">Full Name</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">badge</span>
<input class="w-full pl-12 pr-4 py-3.5 bg-background-light dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary text-slate-900 dark:text-slate-100 placeholder:text-slate-400" placeholder="John Doe" type="text"/>
</div>
</div>
<div class="flex flex-col gap-2">
<label class="text-slate-900 dark:text-slate-100 text-sm font-semibold">Email Address</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">mail</span>
<input class="w-full pl-12 pr-4 py-3.5 bg-background-light dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary text-slate-900 dark:text-slate-100 placeholder:text-slate-400" placeholder="john@example.com" type="email"/>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="flex flex-col gap-2">
<label class="text-slate-900 dark:text-slate-100 text-sm font-semibold">Password</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock</span>
<input class="w-full pl-12 pr-4 py-3.5 bg-background-light dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary text-slate-900 dark:text-slate-100 placeholder:text-slate-400" placeholder="••••••••" type="password"/>
</div>
</div>
<div class="flex flex-col gap-2">
<label class="text-slate-900 dark:text-slate-100 text-sm font-semibold">Confirm Password</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">key_visualizer</span>
<input class="w-full pl-12 pr-4 py-3.5 bg-background-light dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary text-slate-900 dark:text-slate-100 placeholder:text-slate-400" placeholder="••••••••" type="password"/>
</div>
</div>
</div>
</div>
<div class="flex items-start gap-3 py-2">
<div class="flex h-5 items-center">
<input class="h-5 w-5 rounded border-slate-300 text-primary focus:ring-primary" id="terms" type="checkbox"/>
</div>
<div class="text-sm leading-6">
<label class="font-medium text-slate-700 dark:text-slate-300" for="terms">
                            I agree to the <a class="text-primary hover:underline" href="#">Terms of Service</a> and <a class="text-primary hover:underline" href="#">Privacy Policy</a>.
                        </label>
</div>
</div>
<button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 px-6 rounded-lg transition-all shadow-lg shadow-primary/25 flex items-center justify-center gap-2" type="submit">
<span>Create Account</span>
<span class="material-symbols-outlined text-lg">arrow_forward</span>
</button>
<a class="w-full inline-flex items-center justify-center py-3 px-4 border border-primary/30 text-primary font-bold rounded-lg hover:bg-primary/5 transition-colors" href="/marketplace">Visitante</a>
</form>
<div class="mt-8 pt-6 border-t border-primary/10 flex flex-col items-center gap-4">
<p class="text-sm text-slate-500">Or sign up with</p>
<div class="flex gap-4 w-full">
<button class="flex-1 flex items-center justify-center gap-2 py-2.5 px-4 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
<svg aria-hidden="true" class="w-5 h-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path></svg>
<span class="text-sm font-medium text-slate-700 dark:text-slate-200">Google</span>
</button>
<button class="flex-1 flex items-center justify-center gap-2 py-2.5 px-4 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
<svg aria-hidden="true" class="w-5 h-5 text-slate-900 dark:text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>
<span class="text-sm font-medium text-slate-700 dark:text-slate-200">GitHub</span>
</button>
</div>
</div>
</div>
</main>
<footer class="p-8 text-center text-slate-500 dark:text-slate-400 text-sm">
<p>© 2026 DEVHUB Ecosystem. All rights reserved.</p>
