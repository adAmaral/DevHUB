9:T23e5,<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
<div class="layout-container flex h-full grow flex-col">
<!-- Top Navigation Bar -->
<header class="flex items-center justify-between whitespace-nowrap border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 lg:px-10 py-3 sticky top-0 z-50">
<div class="flex items-center gap-4">
<div class="size-8 flex items-center justify-center">
<img alt="DEVHUB logo" class="size-8 rounded-lg object-cover" src="/assets/devhublogo.jpeg"/>
</div>
<h2 class="text-slate-900 dark:text-white text-xl font-black leading-tight tracking-tight">DEVHUB</h2>
</div>
<div class="flex items-center gap-4">
<span class="hidden sm:inline text-slate-500 dark:text-slate-400 text-sm">Already have an account?</span>
<a class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-6 bg-primary text-white text-sm font-bold leading-normal tracking-wide transition-all hover:bg-primary/90" href="/login">
                    Log In
                </a>
</div>
</header>
<!-- Main Content Section -->
<main class="flex-1 flex items-center justify-center p-4 md:p-10">
<div class="w-full max-w-[560px] bg-white dark:bg-slate-900 rounded-xl shadow-xl shadow-primary/5 border border-slate-200 dark:border-slate-800 overflow-hidden">
<!-- Card Header -->
<div class="p-8 pb-4 text-center">
<h1 class="text-3xl font-black text-slate-900 dark:text-white mb-2">Create Company Account</h1>
<p class="text-slate-500 dark:text-slate-400">Join the world's most innovative company ecosystem</p>
</div>
<!-- User Type Selection -->
<div class="px-8 py-4">
<p class="text-sm font-bold text-slate-700 dark:text-slate-300 mb-4">I am joining as a...</p>
<div class="grid grid-cols-3 gap-3">
<!-- Company Option -->
<a class="group flex flex-col items-center justify-center p-4 rounded-xl border-2 border-primary bg-primary/5 dark:bg-primary/10 transition-all" href="/create-account-company">
<span class="material-symbols-outlined text-primary mb-2">corporate_fare</span>
<span class="text-xs font-bold text-primary uppercase tracking-wider">Company</span>
</a>
<!-- Regular User Option (Active) -->
<a class="group flex flex-col items-center justify-center p-4 rounded-xl border-2 border-slate-100 dark:border-slate-800 hover:border-primary/50 transition-all bg-slate-50 dark:bg-slate-800/50" href="/create-account">
<span class="material-symbols-outlined text-slate-500 dark:text-slate-400 group-hover:text-primary mb-2">person</span>
<span class="text-xs font-bold text-slate-600 dark:text-slate-400 group-hover:text-primary uppercase tracking-wider">Developer</span>
</a>
<!-- Supplier Option -->
<a class="group flex flex-col items-center justify-center p-4 rounded-xl border-2 border-slate-100 dark:border-slate-800 hover:border-primary/50 transition-all bg-slate-50 dark:bg-slate-800/50" href="/create-account-supplier">
<span class="material-symbols-outlined text-slate-500 dark:text-slate-400 group-hover:text-primary mb-2">local_shipping</span>
<span class="text-xs font-bold text-slate-600 dark:text-slate-400 group-hover:text-primary uppercase tracking-wider">Supplier</span>
</a>
</div>
</div>
<!-- Form Section -->
<div class="px-8 pb-10 space-y-5">
<!-- Full Name -->
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Company Name</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">badge</span>
<input class="w-full pl-10 pr-4 py-3.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-slate-900 dark:text-white placeholder:text-slate-400" placeholder="e.g. Nexa Systems Ltd" type="text"/>
</div>
</div>
<!-- Email -->
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Email Address</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">mail</span>
<input class="w-full pl-10 pr-4 py-3.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-slate-900 dark:text-white placeholder:text-slate-400" placeholder="contact@company.com" type="email"/>
</div>
</div>
<!-- Password -->
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Password</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
<input class="w-full pl-10 pr-12 py-3.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-slate-900 dark:text-white placeholder:text-slate-400" placeholder="••••••••" type="password"/>
<button class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
<span class="material-symbols-outlined text-lg">visibility</span>
</button>
</div>
</div>
<!-- Terms Checkbox -->
<div class="flex items-start gap-3 pt-2">
<input class="mt-1 size-5 rounded border-slate-300 text-primary focus:ring-primary/20 transition-all cursor-pointer" id="terms" type="checkbox"/>
<label class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed cursor-pointer" for="terms">
                            I agree to the <a class="text-primary font-bold hover:underline" href="#">Terms of Service</a> and <a class="text-primary font-bold hover:underline" href="#">Privacy Policy</a>.
                        </label>
</div>
<!-- Submit Button -->
<button class="w-full py-4 bg-primary text-white font-black text-lg rounded-lg shadow-lg shadow-primary/20 hover:shadow-primary/40 hover:-translate-y-0.5 active:translate-y-0 transition-all">
                        Create Company Account
                    </button>
<a class="w-full inline-flex items-center justify-center py-3 px-4 border border-primary/30 text-primary font-bold rounded-lg hover:bg-primary/5 transition-colors" href="/marketplace">Visitante</a>
<!-- Divider -->
<div class="relative flex items-center py-4">
<div class="flex-grow border-t border-slate-200 dark:border-slate-800"></div>
<span class="flex-shrink mx-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Or sign up with</span>
<div class="flex-grow border-t border-slate-200 dark:border-slate-800"></div>
</div>
<!-- Social Logins -->
<div class="grid grid-cols-2 gap-4">
<button class="flex items-center justify-center gap-2 py-3 px-4 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
<svg aria-hidden="true" class="size-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path></svg>
<span class="text-sm font-bold text-slate-700 dark:text-slate-300">Google</span>
</button>
<button class="flex items-center justify-center gap-2 py-3 px-4 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
<svg aria-hidden="true" class="size-5 text-slate-900 dark:text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>
<span class="text-sm font-bold text-slate-700 dark:text-slate-300">GitHub</span>
</button>
</div>
</div>
</div>
</main>
<!-- Simple Footer -->
<footer class="py-6 text-center">
<p class="text-slate-400 dark:text-slate-600 text-sm">
                © 2026 DEVHUB Inc. All rights reserved.
            </p>
</footer>
</div>
</div>2:["$","main",null,{"className":"bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased","children":["$","div",null,{"dangerouslySetInnerHTML":{"__html":"$9"}}]}]
