<div class="bg-primary/10 rounded-2xl flex items-center justify-center p-4 h-24 w-24 md:h-32 md:w-32">
<span class="material-symbols-outlined text-primary text-5xl">cloud_done</span>
</div>
<div class="flex flex-col">
<h1 class="text-slate-900 dark:text-slate-100 text-3xl font-extrabold tracking-tight">CloudScale Pro</h1>
<p class="text-primary font-semibold">by NexaSystems Inc.</p>
<div class="flex items-center gap-2 mt-1">
