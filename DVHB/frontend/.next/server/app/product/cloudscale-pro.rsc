<span class="material-symbols-outlined text-slate-400 text-sm">chevron_right</span>
<span class="text-slate-900 dark:text-slate-100 text-sm font-bold">CloudScale Pro</span>
</div>
<!-- Hero Section -->
<section class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pb-8 border-b border-slate-200 dark:border-slate-800">
