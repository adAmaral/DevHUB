</div>
<div class="p-4 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-primary/50 transition-colors cursor-pointer">
<div class="flex justify-between items-center mb-1">
<span class="font-bold">Starter</span>
<span class="text-lg font-extrabold">$49<span class="text-xs font-normal">/mo</span></span>
</div>
<p class="text-xs text-slate-500 dark:text-slate-400">Up to 5 nodes, Basic Support</p>
</div>
<div class="p-4 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-primary/50 transition-colors cursor-pointer">
<div class="flex justify-between items-center mb-1">
<span class="font-bold">Enterprise</span>
<span class="text-lg font-extrabold">Custom</span>
</div>
<p class="text-xs text-slate-500 dark:text-slate-400">Dedicated instance, 24/7 Support</p>
</div>
</div>
<a href="/checkout" class="w-full mt-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 transition-colors inline-flex items-center justify-center">Select Plan</a>
</div>
<!-- Product Details -->
<div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800">
<h3 class="text-lg font-bold mb-4">Product Details</h3>
