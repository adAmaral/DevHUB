# ==============================
# VARIÁVEIS DE AMBIENTE - FIREBASE
# ==============================

# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no Git!

# ===== FIREBASE ADMIN SDK =====
# Opção 1: Usar credenciais individuais (recomendado para produção)
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# Opção 2: Usar JSON completo da service account (alternativa)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ===== SERVIDOR =====
PORT=8080
NODE_ENV=development

# ===== VERCEL (se usar deploy no Vercel) =====
# VERCEL=1

